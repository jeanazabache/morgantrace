{
  "title": "MorganTrace — Detección de Fraude",
  "uid": "morgantrace-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "tags": ["morgantrace", "fraude", "ml"],
  "panels": [
    {
      "id": 1,
      "title": "Transacciones analizadas (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(morgantrace_predicciones_total)",
          "legendFormat": "Total predicciones"
        }
      ]
    },
    {
      "id": 2,
      "title": "Fraudes detectados (total)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "morgantrace_fraudes_detectados_total",
          "legendFormat": "Fraudes"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tasa de fraude (%)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 * morgantrace_fraudes_detectados_total / clamp_min(sum(morgantrace_predicciones_total), 1)",
          "legendFormat": "% Fraude"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latencia p95 del endpoint /predict (ms)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler='/predict'}[5m])) by (le)) * 1000",
          "legendFormat": "p95 latencia"
        }
      ]
    },
    {
      "id": 5,
      "title": "Tasa de requests por endpoint (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{handler='/predict'}[1m]))",
          "legendFormat": "POST /predict"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{handler='/predict/batch'}[1m]))",
          "legendFormat": "POST /predict/batch"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{handler='/health'}[1m]))",
          "legendFormat": "GET /health"
        }
      ]
    },
    {
      "id": 6,
      "title": "Latencia de inferencia por percentil (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler='/predict'}[5m])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler='/predict'}[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{handler='/predict'}[5m])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 7,
      "title": "Transacciones por nivel de riesgo (último minuto)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "BAJO" },  "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "MEDIO" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "ALTO" },  "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(morgantrace_predicciones_total{nivel_riesgo='BAJO'}[1m]))",
          "legendFormat": "BAJO"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(morgantrace_predicciones_total{nivel_riesgo='MEDIO'}[1m]))",
          "legendFormat": "MEDIO"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(morgantrace_predicciones_total{nivel_riesgo='ALTO'}[1m]))",
          "legendFormat": "ALTO"
        }
      ]
    },
    {
      "id": 8,
      "title": "Tasa de errores HTTP (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx (servidor)" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx (cliente)" },  "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{status_code=~'5..'}[1m]))",
          "legendFormat": "5xx (servidor)"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{status_code=~'4..'}[1m]))",
          "legendFormat": "4xx (cliente)"
        }
      ]
    }
  ]
}
